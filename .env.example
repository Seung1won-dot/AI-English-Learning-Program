# ===========================================================
#  AI 키 설정 — 아래 중 "하나만" 채우면 됩니다.
#  아무것도 안 채워도 규칙기반(목업) 피드백으로 정상 동작합니다.
#  우선순위: GROQ_API_KEY > OPENAI_API_KEY > 목업
# ===========================================================

# ▶ 무료 AI (추천) — Groq
#   https://console.groq.com 에서 무료 가입 후 API Key 발급
GROQ_API_KEY=
# 사용할 모델 (선택) — 기본값: llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile

# ▶ 유료 AI — OpenAI (쓰고 싶을 때만)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
